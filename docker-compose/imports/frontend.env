# =============================================================================
# NL Portal Frontend Configuration
# =============================================================================
# Variables are injected into window.* at runtime via config.js/config.template.js.
# Pattern: window.VAR_NAME in browser, VAR_NAME in this file.
# Frontend features are configured on the backend (nl-portal.config.features.*,
# served via GET /api/public/features), not here.
# =============================================================================

# -----------------------------------------------------------------------------
# API Endpoints (required)
# -----------------------------------------------------------------------------
GRAPHQL_URI=http://localhost:8080/graphql
REST_URI=http://localhost:8080/api

# -----------------------------------------------------------------------------
# OIDC Authentication (required)
# -----------------------------------------------------------------------------
OIDC_URL=http://localhost:8082/auth
OIDC_REALM=nlportal
OIDC_CLIENT_ID=nl-portal
OIDC_REDIRECT_URI=http://localhost:3000/oidc/callback
OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:3000

# -----------------------------------------------------------------------------
# OIDC Session Management (optional)
# Idle logout enabled by default (15 min). Set to false to disable.
# -----------------------------------------------------------------------------
OIDC_AUTO_IDLE_SESSION_LOGOUT=true
OIDC_IDLE_TIMEOUT_MINUTES=15
