extend type Query {
    # Gets the profile for the user
    getBurgerProfiel: Klant
}
extend type Mutation {
    # Updates the profile for the user
    updateBurgerProfiel(klant: KlantUpdateInput!): Klant
}

input KlantUpdateInput {
    aanmaakkanaal: String
    emailadres: String
    telefoonnummer: String
}

type Klant {
    aanmaakkanaal: String
    emailadres: String
    telefoonnummer: String
}
