extend type Query {
    # Get DigitaleAdressen of authenticated user.
    getUserDigitaleAdressen: [DigitaleAdresResponse!]

    # Get KlantContact by id of authenticated user.
    getUserKlantContact(klantContactId: UUID!): OpenKlant2Klantcontact

    #
    #         Get KlantContacten of authenticated user and optional filter on .
    #         identificatorType, like zaak or product
    #         identificatorId, the uuid of the zaak or product
    #
    getUserKlantContacten(
        identificatorType: OnderwerpObjectIndentificatorType
        identificatorId: UUID
    ): [OpenKlant2Klantcontact!]!

    # Find the Partij of the authenticated user.
    findUserPartij: OpenKlant2Partij

    # Get Partij by Id for authenticated user.
    getUserPartij(partijId: UUID!): OpenKlant2Partij

}

extend type Mutation {
    # Create DigitaleAdres for User
    createUserDigitaleAdres(
        digitaleAdresRequest: DigitaleAdresRequestInput!
    ): DigitaleAdresResponse

    # Delete DigitaleAdres of User by Id
    deleteUserDigitaleAdres(digitaleAdresId: UUID!): Boolean

    # Update DigitaleAdres of User
    updateUserDigitaleAdres(
        digitaleAdresRequest: DigitaleAdresRequestInput!
    ): DigitaleAdresResponse

    # Create Partij for user
    createUserPartij(partijRequest: PartijRequestInput!): PartijResponse

    # Update user Partij
    updateUserPartij(partijRequest: PartijRequestInput!): PartijResponse
}

type Betrokkene {
    bezoekadres: OpenKlant2Adres
    contactnaam: Contactnaam
    correspondentieadres: OpenKlant2Adres
    digitaleAdressen: [OpenKlant2ForeignKey!]!
    hadKlantcontact: OpenKlant2ForeignKey!
    initiator: Boolean!
    organisatienaam: String!
    rol: String!
    url: String!
    uuid: String!
    volledigeNaam: String!
    wasPartij: OpenKlant2ForeignKey
}

type Categorie {
    naam: String!
    url: String!
    uuid: String!
}

type CategorieRelatie {
    beginDatum: Date
    categorie: Categorie
    eindDatum: Date
    partij: OpenKlant2ForeignKey
    url: String!
    uuid: String!
}

type CategorieRelatieForeignKey {
    beginDatum: Date
    categorieNaam: String!
    eindDatum: Date
    url: String!
    uuid: String!
}

type ContactpersoonIdentificatie {
    contactnaam: Contactnaam
    uuid: UUID
    volledigeNaam: String
    werkteVoorPartij: OpenKlant2ForeignKey
}

input ContactpersoonIdentificatieInput {
    contactnaam: ContactnaamInput
    uuid: UUID
    volledigeNaam: String
    werkteVoorPartij: OpenKlant2ForeignKeyInput
}

type Contactnaam {
    achternaam: String
    voorletters: String
    voornaam: String
    voorvoegselAchternaam: String
}

input ContactnaamInput {
    achternaam: String
    voorletters: String
    voornaam: String
    voorvoegselAchternaam: String
}

input DigitaleAdresRequestInput {
    omschrijving: String!
    type: DigitaleAdresType!
    uuid: UUID
    waarde: String!
}

type DigitaleAdresResponse {
    omschrijving: String!
    referentie: String!
    type: DigitaleAdresType!
    uuid: UUID!
    verificatieDatum: Date
    waarde: String!
    isGeverifieerd: Boolean!
}

enum DigitaleAdresType {
    TELEFOONNUMMER
    EMAIL
    OVERIG
}

type HadBetrokkenActoren {
    actoridentificator: OpenKlant2Identificator!
    indicatieActief: Boolean!
    naam: String!
    soortActor: String!
    url: String!
    uuid: String!
}

type HadKlantcontact {
    gingOverOnderwerpobjecten: [OpenKlant2ForeignKey!]!
    hadBetrokkenActoren: [HadBetrokkenActoren!]!
    hadBetrokkenen: [OpenKlant2ForeignKey!]!
    indicatieContactGelukt: Boolean!
    inhoud: String!
    kanaal: String!
    leiddeTotInterneTaken: [OpenKlant2ForeignKey!]!
    nummer: String!
    omvatteBijlagen: [OpenKlant2ForeignKey!]!
    onderwerp: String!
    plaatsgevondenOp: String!
    taal: String!
    url: String!
    uuid: String!
    vertrouwelijk: Boolean!
}

enum OnderwerpObjectIndentificatorType {
    ZAAK
    PRODUCT
}

type OpenKlant2Adres {
    adresregel1: String
    adresregel2: String
    adresregel3: String
    land: OpenKlant2Landcode
    nummeraanduidingId: String
}

type OpenKlant2DigitaleAdres {
    adres: String!
    omschrijving: String!
    referentie: String
    soortDigitaalAdres: String!
    url: String
    uuid: UUID
    verstrektDoorBetrokkene: OpenKlant2UUID
    verstrektDoorPartij: OpenKlant2UUID
}

type OpenKlant2ForeignKey {
    url: String!
    uuid: UUID!
}

input OpenKlant2ForeignKeyInput {
    url: String!
    uuid: UUID!
}

type OpenKlant2Identificator {
    codeObjecttype: String!
    codeRegister: String!
    codeSoortObjectId: String!
    objectId: String!
}

type OpenKlant2IdentificeerdePartij {
    uuid: UUID!
}

type OpenKlant2Klantcontact {
    gingOverOnderwerpobjecten: [OpenKlant2ForeignKey!]!
    hadBetrokkenActoren: [HadBetrokkenActoren!]!
    hadBetrokkenen: [OpenKlant2ForeignKey!]!
    indicatieContactGelukt: Boolean!
    inhoud: String!
    kanaal: String!
    leiddeTotInterneTaken: [OpenKlant2ForeignKey!]!
    nummer: String!
    omvatteBijlagen: [OpenKlant2ForeignKey!]!
    onderwerp: String!
    plaatsgevondenOp: String!
    taal: String!
    url: String!
    uuid: String!
    vertrouwelijk: Boolean!
}

