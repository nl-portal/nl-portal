# A Type that represents a Klantinteracties API Partij object
type OpenKlant2Partij {
    betrokkenen: [OpenKlant2ForeignKey!]
    bezoekadres: OpenKlant2Adres
    categorieRelaties: [CategorieRelatieForeignKey!]
    correspondentieadres: OpenKlant2Adres
    digitaleAdressen: [OpenKlant2ForeignKey!]
    expand: PartijExpand
    indicatieActief: Boolean!
    indicatieGeheimhouding: Boolean
    interneNotitie: String
    nummer: String
    partijIdentificatie: PartijIdentificatie!
    partijIdentificatoren: [OpenKlant2PartijIdentificator!]
    rekeningnummers: [OpenKlant2ForeignKey!]
    soortPartij: SoortPartij!
    url: String
    uuid: UUID
    vertegenwoordigden: [OpenKlant2ForeignKey!]
    voorkeursDigitaalAdres: OpenKlant2ForeignKey
    voorkeursRekeningnummer: OpenKlant2ForeignKey
    voorkeurstaal: String
}

type OpenKlant2PartijIdentificator {
    anderePartijIdentificator: String
    identificeerdePartij: OpenKlant2IdentificeerdePartij
    partijIdentificator: OpenKlant2Identificator
    subIdentificatorVan: OpenKlant2SubIdentificatorVan
    url: String
    uuid: UUID
}

type OrganisatieIdentificatie {
    naam: String
}

input OrganisatieIdentificatieInput {
    naam: String
}

type PartijExpand {
    betrokkenen: [Betrokkene!]
    categorieRelaties: [CategorieRelatie!]
    digitaleAdressen: [OpenKlant2DigitaleAdres!]
    hadKlantcontact: [HadKlantcontact!]
}

union PartijIdentificatie =
    ContactpersoonIdentificatie
    | OrganisatieIdentificatie
    | PersoonsIdentificatie

input PartijRequestInput {
    contactpersoonIdentificatie: ContactpersoonIdentificatieInput
    indicatieActief: Boolean!
    indicatieGeheimhouding: Boolean!
    organisatieIdentificatie: OrganisatieIdentificatieInput
    persoonsIdentificatie: PersoonsIdentificatieInput
    type: PartijType!
}

type PartijResponse {
    contactpersoonIdentificatie: ContactpersoonIdentificatie
    digitaleAdressen: [OpenKlant2DigitaleAdres!]
    indicatieActief: Boolean!
    indicatieGeheimhouding: Boolean
    klantcontacten: [HadKlantcontact!]
    organisatieIdentificatie: OrganisatieIdentificatie
    persoonsIdentificatie: PersoonsIdentificatie
    type: PartijType!
}

enum PartijType {
    PERSOON
    ORGANISATIE
    CONTACTPERSOON
}

type PersoonsIdentificatie {
    contactnaam: Contactnaam
    volledigeNaam: String
}

input PersoonsIdentificatieInput {
    contactnaam: ContactnaamInput
    volledigeNaam: String
}

type OpenKlant2SubIdentificatorVan {
    uuid: UUID!
}

type OpenKlant2UUID {
    uuid: UUID!
}

enum SoortPartij {
    PERSOON
    ORGANISATIE
    CONTACTPERSOON
}

input VerificatieCreateInput {
    type: DigitaleAdresType!
    uuid: UUID!
    waarde: String!
}
