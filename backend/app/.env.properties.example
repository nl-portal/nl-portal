# --- Prefill (host uses localhost, not host.docker.internal) ---
NLPORTAL_CONFIG_PREFILL_ENABLED=true
NLPORTAL_CONFIG_PREFILL_PROPERTIES_TYPEURL=http://localhost:8011/api/v2/objecttypes/3e852115-277a-4570-873a-9a64be3aeb37

# --- DMN ---
NLPORTAL_CONFIG_DMN_ENABLED=true
NLPORTAL_CONFIG_DMN_PROPERTIES_URL=http://localhost:8010

# --- OIDC realm ---
OIDC_REALM=nlportal

