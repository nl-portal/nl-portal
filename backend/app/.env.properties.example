# Local development config for `:app:bootRun` (sources mode).
# Copy to `.env.properties` (gitignored) and adjust for your machine.
# See backend/app/README.md for what this is and how it differs from the
# containerised docker-compose/imports/backend.env.

# --- Development overlay ---
DATABASE_URL=jdbc:postgresql://localhost:5432/nl-portal
LOGLEVEL=DEBUG
SPRING_GRAPHQL_SCHEMA_INTROSPECTION_ENABLED=true

# --- Database ---
DATABASE_USERNAME=nlportal
DATABASE_PASSWORD=password

# --- Configuration Panel ---
CONFIGURATION_PANEL_ENABLED=true
CONFIGURATION_PANEL_TOKEN=VerySecretToken
CONFIGURATION_PANEL_URI=http://localhost:8090/configuration
CONFIGURATION_PANEL_APPLICATION_NAME=nl-portal-app

# --- Keycloak ---
JWKS_URI=http://localhost:8082/auth/realms/nlportal/protocol/openid-connect/certs
KEYCLOAK_CLIENT_ID=nl-portal-m2m
KEYCLOAK_CLIENT_SECRET=ookVRUAxmEWMcosfcGR5nxeoUC4Rgwbc
KEYCLOAK_TOKEN_EXCHANGE_AUDIENCE=nl-portal-token-exchange

# --- Objecten API ---
NLPORTAL_CONFIG_OBJECTENAPI_ENABLED=true
NLPORTAL_CONFIG_OBJECTENAPI_PROPERTIES_URL=http://localhost:8010
NLPORTAL_CONFIG_OBJECTENAPI_PROPERTIES_TOKEN=182c13e2209161852c53cef53a879f7a2f923430

# --- Zaken API ---
NLPORTAL_CONFIG_ZAKENAPI_ENABLED=true
