{
  "name": "@nl-portal/nl-portal-api",
  "version": "3.1.0-next-minor-202602101504-e45ed5c4-SNAPSHOT",
  "author": "Ritense",
  "license": "EUPL-1.2",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "pnpm wait && tsc && vite build",
    "clean": "rimraf dist",
    "codegen": "graphql-codegen --config codegen.ts",
    "dev": "pnpm wait && vite build --watch --mode development",
    "preinstall": "npx only-allow pnpm",
    "wait": "wait-on ../authentication/dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@apollo/client": "4.0.11",
    "graphql": "^16.12.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.1.0",
    "@graphql-codegen/client-preset": "^5.2.1",
    "@graphql-typed-document-node/core": "3.2.0",
    "@nl-portal/nl-portal-authentication": "workspace:*",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.16",
    "wait-on": "^9.0.3"
  },
  "peerDependencies": {
    "@nl-portal/nl-portal-authentication": "workspace:*",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  }
}
