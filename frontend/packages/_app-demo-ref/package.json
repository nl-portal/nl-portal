{
  "name": "@nl-portal/nl-portal-app",
  "private": true,
  "version": "1.0.0",
  "author": "Ritense",
  "license": "EUPL-1.2",
  "type": "module",
  "scripts": {
    "dev": "pnpm wait && vite --port 3000 --mode development",
    "build": "pnpm wait && tsc && vite build",
    "preinstall": "npx only-allow pnpm",
    "preview": "vite preview",
    "clean": "rimraf dist",
    "wait": "wait-on ../api/dist/index.js && wait-on ../authentication/dist/index.js && wait-on ../localization/dist/index.js && wait-on ../user-interface/dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@gemeente-denhaag/design-tokens-components": "3.0.1",
    "@gemeente-denhaag/icons": "3.0.2",
    "@gemeente-denhaag/link": "2.0.2",
    "@gemeente-denhaag/typography": "2.0.5",
    "@nl-portal/nl-portal-api": "workspace:*",
    "@nl-portal/nl-portal-authentication": "workspace:*",
    "@nl-portal/nl-portal-localization": "workspace:*",
    "@nl-portal/nl-portal-user-interface": "workspace:*",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router": "^7.4.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.1",
    "@vitejs/plugin-react": "^4.5.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.2",
    "wait-on": "^8.0.3"
  }
}
