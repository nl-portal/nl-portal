{
  "name": "nl-portal-app",
  "version": "0.0.0",
  "author": "Ritense",
  "packageManager": "pnpm",
  "license": "EUPL-1.2",
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0 <12"
  },
  "scripts": {
    "dev": "pnpm wait && vite --port 3000 --mode development",
    "wait": "wait-on ../api/dist/index.js && wait-on ../authentication/dist/index.js && wait-on ../localization/dist/index.js && wait-on ../user-interface/dist/index.js",
    "build": "tsc && vite build",
    "preinstall": "npx only-allow pnpm",
    "preview": "vite preview --port 3000",
    "generate-pwa-assets": "pwa-asset-generator ./src/assets/pwa-logo.svg ./public/pwa --favicon --mstile --opaque  false --maskable true --index  index.html --manifest ./public/manifest.json --path-override '../pwa'",
    "clean": "rimraf build",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@apollo/client": "4.0.11",
    "@gemeente-denhaag/design-tokens-components": "5.1.0",
    "@gemeente-denhaag/icons": "4.0.0",
    "@nl-portal/nl-portal-api": "workspace:*",
    "@nl-portal/nl-portal-authentication": "workspace:*",
    "@nl-portal/nl-portal-localization": "workspace:*",
    "@nl-portal/nl-portal-user-interface": "workspace:*",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-intl": "^7.1.14",
    "react-router": "^7.10.1"
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.60.1",
    "@typescript-eslint/parser": "8.60.1",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "16.4.0",
    "jsdom": "29.1.1",
    "pwa-asset-generator": "8.1.5",
    "rimraf": "6.1.3",
    "typescript": "5.9.3",
    "vite": "^8.0.16",
    "vitest": "4.1.8",
    "wait-on": "9.0.3"
  }
}
