{
  "name": "nl-portal-frontend",
  "private": true,
  "packages": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm clean && pnpm run --recursive --parallel build",
    "build:watch": "pnpm clean && pnpm run --recursive --parallel build:watch",
    "clean": "pnpm run --recursive clean",
    "codegen": "pnpm run --recursive --parallel codegen",
    "dev": "pnpm clean && pnpm run --recursive --parallel dev",
    "lint": "eslint \"packages/**/*.{js,jsx,ts,tsx}\"",
    "lint:css": "stylelint \"**/*.{css,scss}\"",
    "lint:fix": "eslint \"packages/**/*.{js,jsx,ts,tsx}\" --fix",
    "preinstall": "npx only-allow pnpm",
    "prettier": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "publish": "lerna publish from-package",
    "release": "lerna version 3.1.0 --no-changelog --no-private --no-commit-hooks --message 'chore: released %s [skip ci]'",
    "test": "pnpm run --recursive --parallel test",
    "test:coverage": "pnpm run --recursive --parallel --filter '!./packages/app' test:coverage",
    "typecheck": "pnpm run --recursive --parallel typecheck",
    "update-patch": "npm-check-updates --configFilePath .ncurc.patch.js",
    "update-minor": "npm-check-updates --configFilePath .ncurc.minor.js",
    "update-major": "npm-check-updates --configFilePath .ncurc.major.js",
    "postinstall": "cd .. && husky frontend/.husky",
    "preview": "pnpm run --recursive preview"
  },
  "devDependencies": {
    "@commitlint/cli": "20.2.0",
    "@commitlint/config-conventional": "20.2.0",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "npm-check-updates": "^19.2.0",
    "prettier": "3.7.4",
    "rollup-plugin-peer-deps-external": "2.2.4",
    "stylelint": "16.26.1",
    "stylelint-config-standard-scss": "16.0.0",
    "stylelint-order": "7.0.0",
    "stylelint-selector-bem-pattern": "4.0.1",
    "typescript": "5.9.3",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0 <12"
  },
  "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a"
}
